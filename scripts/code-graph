#!/usr/bin/env bash
set -euo pipefail

if command -v code-graph >/dev/null 2>&1; then
  exec code-graph "$@"
fi

if [ -x "/home/user/.cargo/bin/code-graph" ]; then
  exec /home/user/.cargo/bin/code-graph "$@"
fi

echo "code-graph is not available on PATH or at /home/user/.cargo/bin/code-graph" >&2
exit 127
